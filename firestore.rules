rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dati utente privati — invariati
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Nuclei condivisi
    match /nuclei/{nid} {
      // Tutti gli utenti autenticati possono leggere (necessario per lookup inviteCode)
      allow read: if request.auth != null;
      // Solo i membri possono aggiornare, oppure un non-membro può aggiungersi (join)
      allow update: if request.auth != null
        && (
          request.auth.uid in resource.data.members
          || (request.auth.uid in request.resource.data.members
              && !(request.auth.uid in resource.data.members)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']))
        );
      // Chiunque può creare, ma deve includere se stesso nei membri
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
    }

    match /nuclei/{nid}/transactions/{txId} {
      // Tutti i membri possono leggere
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/nuclei/$(nid)).data.members;
      // Solo il proprietario può scrivere
      allow create: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/nuclei/$(nid)).data.members
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
